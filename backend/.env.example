# ==============================================================================
# JS Code Analyzer - Backend Environment Variables
# ==============================================================================

# Server configuration
PORT=5000
NODE_ENV=development

# MongoDB database connection string
MONGO_URI=mongodb://127.0.0.1:27017/jscodeanalyzer

# JWT Secrets for Authentication
JWT_SECRET=super_secret_key_jscodeanalyzer_123
JWT_EXPIRES_IN=7d

# Dashboard frontend URL (comma-separated if multiple origins)
DASHBOARD_URL=http://localhost:3000

# Redis configuration (for BullMQ background job queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
